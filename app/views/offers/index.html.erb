<div class="offers-section">
  <h2>Nos Offres Exclusives</h2>

  <div class="offers-grid">
    <% @offers.each do |offer| %>
      <div class="offer-card">
        <% if offer.product&.image_url.present? %>
          <%= image_tag offer.product.image_url, alt: offer.name, class: "offer-card__image" %>
        <% elsif offer.image_url.present? %>
          <%= image_tag offer.image_url, alt: offer.name, class: "offer-card__image" %>
        <% else %>
          <div class="offer-card__image offer-card__image--placeholder" aria-hidden="true"></div>
        <% end %>

        <h3><%= offer.name %></h3>
        <p><%= offer.description %></p>
        <p class="offer-price"><%= number_to_currency(offer.price, unit: "€", format: "%n %u") %></p>

        <%= link_to "Voir cette offre", offer_path(offer), class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
