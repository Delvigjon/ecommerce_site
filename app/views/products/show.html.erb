<section class="product-show-page">

  <div class="product-show-container">

    <nav class="product-show-breadcrumb" aria-label="Fil d’Ariane">
      <%= link_to "Accueil", root_path %>
      <span>/</span>
      <%= link_to "Produits", products_path %>
      <span>/</span>
      <span><%= @product.name %></span>
    </nav>

    <div class="product-show-card">

      <div class="product-show-media">
        <% if @product.image_url.present? %>
          <%= image_tag @product.image_url, alt: @product.name, class: "product-show-image" %>
        <% else %>
          <div class="product-show-image product-show-image--placeholder" aria-hidden="true"></div>
        <% end %>
      </div>

      <div class="product-show-content">
        <h1 class="product-show-title"><%= @product.name %></h1>

        <% if @product.stock.to_i > 0 %>
          <p class="product-show-stock product-show-stock--available">
            En stock : <strong><%= @product.stock %></strong>
          </p>
        <% else %>
          <p class="product-show-stock product-show-stock--unavailable">
            Rupture de stock
          </p>
        <% end %>

        <p class="product-show-price">
          <%= number_to_currency(@product.price, unit: "€", format: "%n %u") %> HT
        </p>

        <% if @product.description.present? %>
          <div class="product-show-description">
            <h2 class="product-show-section-title">Description</h2>
            <p><%= @product.description %></p>
          </div>
        <% end %>

        <div class="product-show-actions">
          <% if @product.stock.to_i > 0 %>
            <%= button_to "Ajouter au panier",
                  cart_cart_items_path(@cart),
                  params: { product_id: @product.id, quantity: 1 },
                  method: :post,
                  class: "product-show-button product-show-button--primary" %>
          <% else %>
            <button class="product-show-button product-show-button--disabled" disabled>
              Indisponible
            </button>
          <% end %>

          <%= link_to "Retour au catalogue", products_path, class: "product-show-button product-show-button--outline" %>
        </div>
      </div>

    </div>

    <% if @related_products.present? %>
      <section class="product-related-section" aria-labelledby="related-products-title">
        <div class="product-related-header">
          <h2 id="related-products-title" class="product-related-title">Produits Similaires</h2>
          <p class="product-related-text">
            Une sélection de luminaires qui pourraient également vous intéresser.
          </p>
        </div>

        <div class="product-related-grid">
          <% @related_products.each do |related_product| %>
            <article class="product-related-card">
              <%= link_to product_path(related_product), class: "product-related-card__media" do %>
                <% if related_product.image_url.present? %>
                  <%= image_tag related_product.image_url, alt: related_product.name, class: "product-related-card__image" %>
                <% else %>
                  <div class="product-related-card__image product-related-card__image--placeholder" aria-hidden="true"></div>
                <% end %>
              <% end %>

              <div class="product-related-card__body">
                <h3 class="product-related-card__title">
                  <%= link_to related_product.name, product_path(related_product) %>
                </h3>

                <p class="product-related-card__price">
                  <%= number_to_currency(related_product.price, unit: "€", format: "%n %u") %> HT
                </p>

                <%= link_to "Voir le produit", product_path(related_product), class: "product-related-card__link" %>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    <% end %>

  </div>

</section>
