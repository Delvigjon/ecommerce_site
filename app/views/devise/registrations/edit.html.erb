<section class="account-edit-page">
  <div class="account-edit-container">

    <header class="account-edit-header">
      <p class="account-edit-kicker">Espace client</p>
      <h1 class="account-edit-title">Modifier mes informations</h1>
      <p class="account-edit-subtitle">
        Mets à jour ton adresse e-mail et ton mot de passe en toute sécurité.
      </p>
    </header>

    <div class="account-edit-card">
      <%= form_for(
            resource,
            as: resource_name,
            url: registration_path(resource_name),
            html: { method: :put, class: "account-edit-form" }
          ) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="account-edit-field">
          <%= f.label :email, "Adresse e-mail", class: "account-edit-label" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "account-edit-input" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="account-edit-notice">
            En attente de confirmation pour :
            <strong><%= resource.unconfirmed_email %></strong>
          </div>
        <% end %>

        <div class="account-edit-field">
          <%= f.label :password, "Nouveau mot de passe", class: "account-edit-label" %>
          <p class="account-edit-help">
            Laisse ce champ vide si tu ne souhaites pas modifier ton mot de passe.
          </p>

          <%= f.password_field :password,
                autocomplete: "new-password",
                class: "account-edit-input" %>

          <% if @minimum_password_length %>
            <p class="account-edit-help">
              <%= @minimum_password_length %> caractères minimum.
            </p>
          <% end %>
        </div>

        <div class="account-edit-field">
          <%= f.label :password_confirmation, "Confirmer le nouveau mot de passe", class: "account-edit-label" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "account-edit-input" %>
        </div>

        <div class="account-edit-field">
          <%= f.label :current_password, "Mot de passe actuel", class: "account-edit-label" %>
          <p class="account-edit-help">
            Ton mot de passe actuel est nécessaire pour valider les modifications.
          </p>
          <%= f.password_field :current_password,
                autocomplete: "current-password",
                class: "account-edit-input" %>
        </div>

        <div class="account-edit-actions">
          <%= f.submit "Enregistrer les modifications", class: "account-edit-save-button" %>
        </div>
      <% end %>
    </div>

    <div class="account-edit-card account-edit-card-delete">
      <h2 class="account-edit-section-title">Supprimer mon compte</h2>
      <p class="account-edit-danger-text">
        Cette action est définitive. Toutes les données associées à ton compte seront supprimées.
      </p>

      <div class="account-edit-danger-actions">
        <%= button_to "Supprimer mon compte",
            registration_path(resource_name),
            method: :delete,
            data: {
              confirm: "Es-tu sûr de vouloir supprimer ton compte ?",
              turbo_confirm: "Es-tu sûr de vouloir supprimer ton compte ?"
            },
            class: "account-edit-delete-button" %>

        <%= link_to "Retour",
            request.referer.presence || root_path,
            class: "account-edit-return-button" %>
      </div>
    </div>

  </div>
</section>
