<div class="auth-links-list">
  <% if controller_name != "sessions" %>
    <%= link_to "Déjà un compte ? Se connecter",
      new_session_path(resource_name),
      class: "auth-link" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Créer un compte",
      new_registration_path(resource_name),
      class: "auth-link" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <%= link_to "Mot de passe oublié ?",
      new_password_path(resource_name),
      class: "auth-link" %>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <%= link_to "Renvoyer les instructions de confirmation",
      new_confirmation_path(resource_name),
      class: "auth-link" %>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <%= link_to "Renvoyer les instructions de déverrouillage",
      new_unlock_path(resource_name),
      class: "auth-link" %>
  <% end %>

  <% if devise_mapping.omniauthable? %>
    <div class="auth-oauth">
      <% resource_class.omniauth_providers.each do |provider| %>
        <%= button_to "Continuer avec #{OmniAuth::Utils.camelize(provider)}",
          omniauth_authorize_path(resource_name, provider),
          class: "btn btn-secondary auth-oauth-btn",
          data: { turbo: false } %>
      <% end %>
    </div>
  <% end %>
</div>
<style>.auth-links-list{
  margin-top: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.auth-link{
  color: rgba(245,245,245,.70);
  text-decoration: none;
  font-size: .95rem;
  transition: 0.2s;
}

.auth-link:hover{
  color: #e7c36a;
}

.auth-oauth{
  margin-top: 6px;
  display: grid;
  gap: 10px;
}

.auth-oauth-btn{
  width: 100%;
}
</style>
