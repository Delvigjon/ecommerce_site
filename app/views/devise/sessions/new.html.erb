<div class="auth-page">
  <div class="auth-card">

    <div class="auth-header">
      <p class="auth-kicker">Espace membre</p>
      <h2 class="auth-title">Connexion</h2>
      <p class="auth-subtitle">
        Accédez à votre compte pour consulter votre panier et vos commandes.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>

      <div class="auth-field">
        <%= f.label :email, "Adresse e-mail", class: "auth-label" %>
        <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "Mot de passe", class: "auth-label" %>
        <%= f.password_field :password,
            autocomplete: "current-password",
            class: "auth-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="auth-row">
          <label class="auth-checkbox">
            <%= f.check_box :remember_me %>
            <span>Se souvenir de moi</span>
          </label>
        </div>
      <% end %>

      <div class="auth-actions">
        <%= f.submit "Se connecter", class: "btn btn-primary auth-submit" %>
      </div>

    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
