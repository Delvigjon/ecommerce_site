<section class="orders-page">

  <div class="orders-container">

    <header class="orders-header">
      <h1 class="orders-title">Mes commandes</h1>
      <p class="orders-subtitle">
        Retrouvez l’historique de vos commandes et consultez leurs détails.
      </p>
    </header>

    <% if @orders.present? %>

      <div class="orders-list">

        <% @orders.each do |order| %>

          <%
            subtotal_ht = order.order_items.sum { |i| i.price * i.quantity }
            tva = subtotal_ht * 0.20
            total_ttc = subtotal_ht + tva
          %>

          <article class="order-card">

            <div class="order-card__main">

              <div class="order-card__info">
                <span class="order-card__id">
                  Commande n°<%= order.id %>
                </span>

                <span class="order-card__date">
                  <%= order.created_at.strftime("%d/%m/%Y") %>
                </span>
              </div>

              <div class="order-card__status order-status--<%= order.status %>">
                <%= order.status.capitalize %>
              </div>

            </div>

            <div class="order-card__items">

              <% order.order_items.limit(3).each do |item| %>
                <div class="order-card__item">
                  <span><%= item.product.name %></span>
                  <span>x<%= item.quantity %></span>
                </div>
              <% end %>

              <% if order.order_items.count > 3 %>
                <span class="order-card__more">
                  + <%= order.order_items.count - 3 %> autres produits
                </span>
              <% end %>

            </div>

            <div class="order-card__footer">

              <div class="order-card__total">
                Total TTC :
                <strong>
                  <%= number_to_currency(total_ttc, unit: "€", format: "%n %u") %>
                </strong>
              </div>

              <%= link_to "Voir la commande",
                  order_path(order),
                  class: "orders-btn orders-btn--primary" %>

            </div>

          </article>

        <% end %>

      </div>

    <% else %>

      <div class="orders-empty">
        <p>Vous n'avez encore passé aucune commande.</p>

        <%= link_to "Découvrir les produits",
            products_path,
            class: "orders-btn orders-btn--primary" %>
      </div>

    <% end %>

  </div>

</section>
