<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">

    <div class="site-footer__grid">

      <!-- Colonne 1 : marque -->
      <div class="site-footer__col site-footer__col--brand">

        <div class="site-footer__logo">
          <svg class="site-footer__logo-svg" viewBox="0 0 340 64" fill="none" xmlns="http://www.w3.org/2000/svg">

            <defs>
              <linearGradient id="goldGradientFooter" x1="0" y1="0" x2="64" y2="64">
                <stop offset="0%" stop-color="#F3D98B"/>
                <stop offset="50%" stop-color="#E7C36A"/>
                <stop offset="100%" stop-color="#C99A2E"/>
              </linearGradient>

              <filter id="softGlowFooter">
                <feGaussianBlur stdDeviation="1.8" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
            </defs>

            <g transform="translate(8 8)" filter="url(#softGlowFooter)">
              <rect x="10" y="18" width="28" height="22" rx="5" fill="url(#goldGradientFooter)"/>
              <path d="M17 19V16.5C17 11.8 20.8 8 25.5 8H22.5C27.1 8 31 11.8 31 16.5V19"
                    stroke="#0B0D10"
                    stroke-width="2.4"
                    stroke-linecap="round"/>
              <circle cx="18" cy="24" r="1.6" fill="#0B0D10"/>
              <circle cx="30" cy="24" r="1.6" fill="#0B0D10"/>
            </g>

            <g transform="translate(58 0)">
              <text x="0" y="28"
                    fill="#F5F5F5"
                    font-family="Georgia, 'Times New Roman', serif"
                    font-size="18"
                    font-weight="700">
                Maison Lumière
              </text>

              <text x="0" y="49"
                    fill="#E7C36A"
                    font-family="Arial, Helvetica, sans-serif"
                    font-size="13"
                    font-weight="700"
                    letter-spacing="1.8">
                ÉCLAIRAGE DESIGN
              </text>
            </g>

          </svg>
        </div>

        <p class="site-footer__text">
          Boutique spécialisée dans les luminaires design et l’éclairage d’ambiance.
          Notre sélection met en avant des pièces modernes et élégantes pensées
          pour sublimer chaque intérieur.
        </p>

        <ul class="site-footer__infos">
          <li>Livraison rapide</li>
          <li>Paiement sécurisé</li>
          <li>Service client disponible</li>
        </ul>

      </div>

      <!-- Colonne 2 -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Navigation</h3>

        <nav class="site-footer__nav" aria-label="Navigation footer">
          <%= link_to "Accueil", root_path %>
          <%= link_to "Produits", products_path %>
          <%= link_to "Promotions", offers_path %>
          <%= link_to "Contact", contact_path %>
          <%= link_to "À propos", about_path %>
        </nav>
      </div>

      <!-- Colonne 3 -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">La boutique</h3>

        <div class="site-footer__nav">
          <%= link_to "Catalogue complet", products_path %>
          <%= link_to "Nos promotions", offers_path %>
          <%= link_to "Mon compte", new_user_session_path %>
          <%= link_to "Mon panier",
              (user_signed_in? && current_user.cart.present? ? cart_path(current_user.cart) : new_user_session_path) %>
        </div>
      </div>

      <!-- Colonne 4 -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Informations</h3>

        <p class="site-footer__text">
          Nous sélectionnons des luminaires au design moderne, pensés pour créer
          une atmosphère chaleureuse et élégante dans chaque pièce de votre intérieur.
        </p>

        <div class="site-footer__badges">
          <span class="site-footer__badge">Design soigné</span>
          <span class="site-footer__badge">Ambiance premium</span>
          <span class="site-footer__badge">Collection contemporaine</span>
        </div>
      </div>

    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__bottom-left">
        <p class="site-footer__copyright">
          © <%= Time.current.year %> Maison Lumière — Tous droits réservés
        </p>

        <p class="site-footer__bottom-note">
          Éclairage design & luminaires contemporains
        </p>
      </div>

      <div class="site-footer__credits">
        <span class="site-footer__credits-label">Site propulsé par</span>

        <%= link_to "https://www.titouweb.com",
            target: "_blank",
            rel: "noopener",
            class: "site-footer__developer" do %>

          <%= image_tag "logo titouweb.png",
              alt: "TitouWeb",
              class: "site-footer__developer-logo" %>

          <span class="site-footer__developer-name">TitouWeb</span>

        <% end %>
      </div>
    </div>

  </div>
</footer>
